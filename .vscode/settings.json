{
    "deno.enable": false, // Desactiva Deno globalmente
    "deno.enablePaths": [
        "supabase/functions"
    ], // Actívalo SOLO aquí
    "deno.lint": true,
    "deno.unstable": [
        "bare-node-builtins",
        "byonm",
        "sloppy-imports",
        "unsafe-proto",
        "webgpu",
        "broadcast-channel",
        "worker-options",
        "cron",
        "kv",
        "ffi",
        "fs",
        "http",
        "net"
    ], // Mantén tu lista actual
    "[typescript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    // Añade esto para evitar que Tailwind choque con Deno
    "tailwindCSS.includeLanguages": {
        "typescript": "javascript",
        "typescriptreact": "javascript"
    },
    "css.lint.unknownAtRules": "ignore",
    "files.associations": {
        "*.css": "tailwindcss"
    }
}